{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Podcast Downloader",
  "version": "0.1.0",
  "identifier": "com.podcastdownloader.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Podcast Downloader",
        "width": 1280,
        "height": 820,
        "minWidth": 1000,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico", "icons/icon.png"]
  }
}
